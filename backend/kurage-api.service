[Unit]
Description=Kurage FastAPI
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/kojima/exdirect/kurage/backend
ExecStart=/usr/bin/python3 -m uvicorn main:app --host 0.0.0.0 --port 18200
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=default.target
